# Pi Developer Portal → App Server API Key (프론트·GitHub에 넣지 마세요)
PI_API_KEY=your_app_server_api_key

# Testnet(샌드박스) 결제용 — Developer Portal Testnet API Key (테스트넷 지갑 입금 필수)
PI_SANDBOX_API_KEY=your_testnet_app_server_api_key

# Testnet 앱 지갑 Private Seed (Developer Portal → Testnet Wallet, A2U 당첨·출금)
# 미설정 시 PI_WALLET_SEED 사용
PI_SANDBOX_WALLET_SEED=S_your_testnet_wallet_private_seed

# 앱 지갑 Private Seed (S_로 시작, Stellar/Pi 메인넷 A2U π 지급용)
PI_WALLET_SEED=S_your_wallet_private_seed

# Pi Platform API (Stellar SCP 기반 Pi 메인넷)
PI_API_BASE=https://api.minepi.com

# production 권장
NODE_ENV=production

# Render가 자동 설정 (로컬만 3000)
PORT=3000

# CORS — GitHub Pages·PiNet Origin (Render 환경 변수에 설정)
# 프론트: https://maducokr.github.io/han/
# 백엔드: https://han-xe9x.onrender.com
CORS_ORIGINS=https://krslotcaaad0999.pinet.com,https://maducokr.github.io,http://localhost:5500,http://127.0.0.1:5500
