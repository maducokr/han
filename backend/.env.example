# Pi Developer Portal → App Server API Key (프론트·GitHub에 넣지 마세요)
PI_API_KEY=your_app_server_api_key

# 앱 지갑 Private Seed (S_로 시작, Stellar/Pi A2U π 지급용)
PI_WALLET_SEED=S_your_wallet_private_seed

# Pi Platform API (Stellar SCP 기반 Pi 메인넷)
PI_API_BASE=https://api.minepi.com

# production 권장
NODE_ENV=production

# Render가 자동 설정 (로컬만 3000)
PORT=3000

# CORS — PiNet Origin만 허용 (Render 환경 변수에 설정)
# 프론트: https://krslotcaaad0999.pinet.com
# 백엔드: https://han-xe9x.onrender.com
CORS_ORIGINS=https://krslotcaaad0999.pinet.com
